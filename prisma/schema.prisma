// Prisma Schema pour Tonomi E-commerce
// Base de données Supabase PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// MODÈLES PRINCIPAUX
// ============================================

model Category {
  id            String    @id @default(uuid())
  name          String
  slug          String    @unique
  description   String    @db.Text
  image         String?   // URL de l'image (Supabase Storage)
  parentId      String?   // Pour les sous-catégories
  parent        Category? @relation("CategoryChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children      Category[] @relation("CategoryChildren")
  productCount  Int       @default(0) // Calculé dynamiquement
  metaTitle     String?
  metaDescription String? @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  products      Product[]

  @@index([slug])
  @@index([parentId])
  @@map("categories")
}

model Product {
  id              String    @id @default(uuid())
  name            String
  slug            String    @unique
  description     String    @db.Text
  shortDescription String   @db.Text
  price           Decimal   @db.Decimal(10, 2)
  originalPrice   Decimal?  @db.Decimal(10, 2)
  categoryId      String
  category        Category  @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  subcategory     String?
  brand           String
  material        String
  stock           Int       @default(0)
  sku             String    @unique
  tags            String[]  @default([])
  badge           String?   // "new" | "promo" | "coup-de-coeur" | "stock-limite"
  rating          Decimal   @default(0) @db.Decimal(3, 2)
  reviewCount     Int       @default(0)
  status          String    @default("draft") // "published" | "draft" | "archived" | "out-of-stock"
  featured        Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  images          ProductImage[]
  colors          ProductColor[]
  sizes           ProductSize[]
  orderItems      OrderItem[]
  reviews         Review[]
  promoProducts   PromoCodeProduct[]

  @@index([slug])
  @@index([categoryId])
  @@index([status])
  @@index([featured])
  @@index([sku])
  @@map("products")
}

model ProductImage {
  id          String   @id @default(uuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url         String   // URL Supabase Storage
  alt         String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([productId])
  @@map("product_images")
}

model ProductColor {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String
  hex       String
  order     Int      @default(0)

  @@index([productId])
  @@map("product_colors")
}

model ProductSize {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String
  order     Int      @default(0)

  @@index([productId])
  @@map("product_sizes")
}

model Customer {
  id          String    @id @default(uuid())
  firstName   String
  lastName    String
  email       String    @unique
  phone       String?
  avatar      String?   // URL Supabase Storage
  segment     String    @default("regular") // "vip" | "new" | "regular" | "inactive"
  totalSpent  Decimal   @default(0) @db.Decimal(10, 2)
  orderCount  Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  addresses   Address[]
  orders      Order[]
  reviews     Review[]

  @@index([email])
  @@map("customers")
}

model Address {
  id          String   @id @default(uuid())
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  label       String
  street      String
  city        String
  zipCode     String
  country     String
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  shippingOrders Order[] @relation("ShippingAddress")
  billingOrders  Order[] @relation("BillingAddress")

  @@index([customerId])
  @@map("addresses")
}

model Order {
  id              String    @id @default(uuid())
  orderNumber     String    @unique
  customerId      String
  customer        Customer  @relation(fields: [customerId], references: [id], onDelete: Restrict)
  subtotal        Decimal   @db.Decimal(10, 2)
  shipping        Decimal   @db.Decimal(10, 2)
  discount        Decimal   @default(0) @db.Decimal(10, 2)
  tax             Decimal   @db.Decimal(10, 2)
  total           Decimal   @db.Decimal(10, 2)
  status          String    @default("pending") // "pending" | "confirmed" | "shipped" | "delivered" | "cancelled" | "refunded"
  paymentMethod   String
  shippingAddressId String
  shippingAddress Address   @relation("ShippingAddress", fields: [shippingAddressId], references: [id])
  billingAddressId String
  billingAddress  Address   @relation("BillingAddress", fields: [billingAddressId], references: [id])
  trackingNumber  String?
  notes           String?   @db.Text
  promoCodeId     String?
  promoCode       PromoCode? @relation(fields: [promoCodeId], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  items           OrderItem[]

  @@index([customerId])
  @@index([orderNumber])
  @@index([status])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id          String   @id @default(uuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  name        String
  price       Decimal  @db.Decimal(10, 2)
  quantity    Int
  color       String?
  size        String?
  image       String   // URL de l'image au moment de la commande

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model Review {
  id          String   @id @default(uuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  rating      Int      // 1-5
  title       String
  comment     String   @db.Text
  status      String   @default("pending") // "pending" | "approved" | "rejected"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([productId])
  @@index([customerId])
  @@index([status])
  @@map("reviews")
}

model PromoCode {
  id          String   @id @default(uuid())
  code        String   @unique
  type        String   // "percentage" | "fixed"
  value       Decimal  @db.Decimal(10, 2)
  minAmount   Decimal? @db.Decimal(10, 2)
  maxUses     Int
  usedCount   Int      @default(0)
  startDate   DateTime
  endDate     DateTime
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  orders      Order[]
  categories  PromoCodeCategory[]
  products    PromoCodeProduct[]

  @@index([code])
  @@index([active])
  @@map("promo_codes")
}

model PromoCodeCategory {
  id          String     @id @default(uuid())
  promoCodeId String
  promoCode   PromoCode  @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  categoryId  String

  @@unique([promoCodeId, categoryId])
  @@index([promoCodeId])
  @@map("promo_code_categories")
}

model PromoCodeProduct {
  id          String     @id @default(uuid())
  promoCodeId String
  promoCode   PromoCode  @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  productId   String
  product     Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([promoCodeId, productId])
  @@index([promoCodeId])
  @@map("promo_code_products")
}

model HeroSlide {
  id          String   @id @default(uuid())
  image       String   // URL Supabase Storage
  title       String
  subtitle   String
  ctaText     String
  ctaLink     String?
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([active])
  @@index([order])
  @@map("hero_slides")
}

model Settings {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String   @db.Text
  type        String   @default("string") // "string" | "number" | "boolean" | "json"
  description String?  @db.Text
  updatedAt   DateTime @updatedAt

  @@map("settings")
}

model Log {
  id          String   @id @default(uuid())
  action      String   // "product_created" | "product_updated" | "order_created" | "customer_created" | "review_created" | etc.
  entityType  String   // "product" | "order" | "customer" | "review" | "category" | "promo" | etc.
  entityId    String?  // ID de l'entité concernée
  description String   @db.Text
  userId      String?  // ID de l'utilisateur/admin qui a effectué l'action
  metadata    String?  @db.Text // JSON pour stocker des données supplémentaires
  createdAt   DateTime @default(now())

  @@index([action])
  @@index([entityType])
  @@index([createdAt])
  @@map("logs")
}
